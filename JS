# Archivo script.js

```javascript
let datosProcesados = {}

function categoria(n){

if(n===0) return "0"
if(n<=2) return "1-2"
if(n<=4) return "3-4"
return "5+"

}

function procesarExcel(data){

const filas = data

let alumnos = {}

filas.forEach(r=>{

let alumno = r[4] + " " + r[5] + " " + r[6]
let etapa = r[10]
let unidad = r[13]
let nota = parseFloat(r[27])

if(!alumnos[alumno]){

alumnos[alumno] = {etapa,unidad,suspensos:0}

}

if(nota < 5) alumnos[alumno].suspensos++

})

let resumen = {}

Object.values(alumnos).forEach(a=>{

let cat = categoria(a.suspensos)

if(!resumen[a.etapa]) resumen[a.etapa] = {}
if(!resumen[a.etapa][a.unidad]) resumen[a.etapa][a.unidad] = {"0":0,"1-2":0,"3-4":0,"5+":0}

resumen[a.etapa][a.unidad][cat]++

})

return resumen

}

document.getElementById("excelFile").addEventListener("change",function(e){

const file = e.target.files[0]

const reader = new FileReader()

reader.onload = function(evt){

const data = new Uint8Array(evt.target.result)
const workbook = XLSX.read(data,{type:"array"})

const sheet = workbook.Sheets[workbook.SheetNames[0]]
const json = XLSX.utils.sheet_to_json(sheet,{header:1})

json.shift()

datosProcesados = procesarExcel(json)

let selector = document.getElementById("nivel")
selector.innerHTML = ""

Object.keys(datosProcesados).forEach(n=>{

let op = document.createElement("option")
op.textContent = n
selector.appendChild(op)

})

mostrar()

}

reader.readAsArrayBuffer(file)

})

function mostrar(){

let nivel = document.getElementById("nivel").value
let datos = datosProcesados[nivel]

let tabla = document.getElementById("tabla")

let html = "<tr><th>Unidad</th><th>0</th><th>1-2</th><th>3-4</th><th>5+</th></tr>"

let labels = []
let valores = []

for(let u in datos){

let d = datos[u]

html += `<tr>
<td>${u}</td>
<td>${d['0']}</td>
<td>${d['1-2']}</td>
<td>${d['3-4']}</td>
<td>${d['5+']}</td>
</tr>`

labels.push(u)
valores.push(d['0'])

}

tabla.innerHTML = html

crearGrafico(labels,valores)

}

function crearGrafico(labels,valores){

const ctx = document.getElementById("grafico")

new Chart(ctx,{ 

type:'bar',

data:{
labels:labels,
datasets:[{
label:'Alumnos sin suspensos',
data:valores
}]
}

})

}

document.getElementById("nivel").addEventListener("change",mostrar)
```

